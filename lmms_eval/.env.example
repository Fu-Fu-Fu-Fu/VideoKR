# Required model checkpoint or Hugging Face repo.
VIDEOKR_MODEL=

# Default task set. Available tasks:
# videokr_eval,videomme,videommmu,mvbench,longvideobench,scivideobench
TASKS=videokr_eval

# Optional local dataset root used by VideoKR_eval.jsonl video paths.
VIDEOKR_EVAL_ROOT=

# Inference settings.
BATCH_SIZE=4
TENSOR_PARALLEL_SIZE=1
DATA_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.85
MAX_MODEL_LEN=32768
MAX_FRAME_NUM=128
MAX_PIXELS=200704
FPS=2
LIMIT=
RUN_NAME=
OUTPUT_PATH=
GEN_KWARGS=

# Cache and download settings.
HF_HOME=~/.cache/huggingface
HF_TOKEN=
# Optional Hugging Face Xet acceleration. Leave disabled if your network is unstable.
HF_XET_HIGH_PERFORMANCE=0

# VLM judge settings. If no usable API credentials are set, multiple-choice
# questions are scored by answer-letter rules and open-ended questions are skipped.
API_TYPE=azure
MODEL_VERSION=gpt-4o
API_VERSION=2024-02-15-preview
AZURE_API_KEY=
AZURE_ENDPOINT=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
VIDEOKR_USE_VLM_JUDGE=
